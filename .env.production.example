# ─────────────────────────────────────────────────────────────
# PRODUCTION environment variables
# Set these in Render.com dashboard, NOT in a file
# ─────────────────────────────────────────────────────────────

# Backend
NODE_ENV=production
PORT=10000
DATABASE_URL=<from render managed postgres>
JWT_SECRET=<96 random chars — render can generate this>
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://atom-fitness-app.onrender.com
LOG_LEVEL=info
BCRYPT_ROUNDS=12

# Frontend (set at build time)
REACT_APP_API_URL=https://atom-fitness-api.onrender.com/api
