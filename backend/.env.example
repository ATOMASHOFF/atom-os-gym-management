# ──────────────────────────────────────────────────────────────
# ATOM FITNESS OS — Backend Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/atom_fitness_db

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_96_CHARACTER_STRING
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Security
BCRYPT_ROUNDS=12

# ── Bootstrap (auto-runs on first startup) ────────────────────
# These create the default gym + super admin automatically.
# Set them in Railway/Render BEFORE first deploy.
DEFAULT_GYM_NAME=Atom OS
SUPER_ADMIN_NAME=Ashish Kumar
SUPER_ADMIN_EMAIL=ashish@mahnwas.com
SUPER_ADMIN_PASSWORD=YourSecurePasswordHere
