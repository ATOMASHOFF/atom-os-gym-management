# ─────────────────────────────────────────────────────────────
# ATOM FITNESS — Backend Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/atom_fitness_db

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_96_CHARACTER_STRING_MINIMUM_32_CHARS
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS and QR code links)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug   # debug | info | warn | error

# Security
BCRYPT_ROUNDS=12  # Use 10 for development/tests (faster), 12 for production
